FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# 1. On copie d'abord les fichiers de dépendances
COPY package.json package-lock.json ./

# 2. On installe TOUTES les dépendances nécessaires pour compiler le projet
RUN npm ci

# 3. On copie tout le reste du code source (depuis le dossier UI_APP)
COPY . .

# 4. On lance la compilation directement sur ton VPS Hostinger (génère le dossier .next)
RUN npm run build

EXPOSE 3000

# 5. On démarre l'application Next.js
CMD ["npm", "run", "start", "--", "-p", "3000"]
