FROM node:20-alpine

WORKDIR /app

ENV PORT=3000

# 1. On copie d'abord les fichiers de dépendances
COPY package.json package-lock.json ./

# 2. On force l'installation de TOUTES les dépendances (y compris TypeScript pour le build)
RUN npm ci --include=dev

# 3. On copie tout le reste du code source
COPY . .

# 4. On lance la compilation (l'alias @/ va maintenant fonctionner !)
RUN npm run build

# 5. On passe en mode production UNIQUEMENT pour l'exécution de l'application
ENV NODE_ENV=production
EXPOSE 3000

# 6. On démarre l'application Next.js
CMD ["npm", "run", "start", "--", "-p", "3000"]
